# Browser LLM Automation Configuration
# Copy this file to .env and fill in your values

# ===========================================
# LLM API Keys (at least one required)
# All providers have free tiers
# ===========================================

# Cerebras API (FREE - very fast inference)
# Get your key at: https://cerebras.ai
CEREBRAS_API_KEY=

# Groq API (FREE - generous limits)
# Get your key at: https://console.groq.com
GROQ_API_KEY=

# Mistral API (FREE - 1 req/sec, 500k tokens/min)
# Get your key at: https://console.mistral.ai
MISTRAL_API_KEY=

# OpenRouter API (FREE models available)
# Get your key at: https://openrouter.ai
OPENROUTER_API_KEY=

# ===========================================
# LinkedIn Credentials
# ===========================================
LINKEDIN_EMAIL=your_email@example.com
LINKEDIN_PASSWORD=your_password

# ===========================================
# Your Profile for Job Applications
# ===========================================
APPLICANT_FIRST_NAME=John
APPLICANT_LAST_NAME=Doe
APPLICANT_NAME=John Doe
APPLICANT_EMAIL=john.doe@email.com
APPLICANT_PHONE=(555) 123-4567
APPLICANT_LOCATION=San Francisco, CA
APPLICANT_LINKEDIN=https://www.linkedin.com/in/johndoe
APPLICANT_YEARS_EXPERIENCE=5+
APPLICANT_TITLE=Software Engineer

# EEO/Demographic Information (for voluntary self-identification forms)
APPLICANT_GENDER=Male
APPLICANT_RACE=Asian

# ===========================================
# Browser Settings (optional)
# ===========================================
# Run browser in headless mode (true/false)
HEADLESS=false

# Slow down actions by this many milliseconds
SLOW_MO=100

